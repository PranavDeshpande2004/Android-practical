<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/main"
    android:orientation="vertical"
    android:padding="12dp"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <EditText
        android:id="@+id/editText"
        android:hint="Enter text"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"/>

    <Button
        android:text="Save Internal"
        android:onClick="saveInternal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"/>

    <Button
        android:text="Read Internal"
        android:onClick="readInternal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"/>

    <Button
        android:text="Save External"
        android:onClick="saveExternal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"/>

    <Button
        android:text="Read External"
        android:onClick="readExternal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"/>

    <TextView
        android:id="@+id/textView"
        android:text="Output"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"/>

</LinearLayout>